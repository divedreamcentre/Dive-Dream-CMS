{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Generic taxonomy reused by Course, Service, FAQ, and GalleryImage"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "appliesTo": {
      "type": "component",
      "component": "shared.list-item",
      "repeatable": true,
      "description": "Allowed values: course, service, blog, faq, gallery"
    }
  }
}
