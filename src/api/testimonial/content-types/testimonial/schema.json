{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "text": {
      "type": "text"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5
    },
    "relatedCourse": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course"
    },
    "relatedService": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::service.service"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    }
  }
}
