{
  "kind": "collectionType",
  "collectionName": "equipment_categories",
  "info": {
    "singularName": "equipment-category",
    "pluralName": "equipment-categories",
    "displayName": "Equipment Category",
    "description": "Generalizes the frontend's current flat equipment string lists into priced, structured cards"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "rentalPrice": {
      "type": "component",
      "component": "shared.pricing",
      "repeatable": false
    },
    "items": {
      "type": "component",
      "component": "shared.list-item",
      "repeatable": true
    }
  }
}
